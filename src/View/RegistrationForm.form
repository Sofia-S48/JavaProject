                </constraints>
                <properties>
                  <text value="Remove"/>
                </properties>
              </component>
            </children>
          </grid>
          <grid id="3e536" binding="SeatchById" layout-manager="GridLayoutManager" row-count="3" column-count="2" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
            <margin top="0" left="0" bottom="0" right="0"/>
            <constraints>
              <tabbedpane title="Search By Event Id"/>
